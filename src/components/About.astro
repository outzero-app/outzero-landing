---
/**
 * About / Story section.
 * Large statement text with brand green highlights.
 * Stats strip removed per feedback.
 */
import type { Locale } from "../i18n/translations";
import { t } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---

<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Pill label -->
      <span
        class="inline-block rounded-full px-4 py-1 text-xs font-semibold tracking-wider uppercase"
        style="background: var(--surface); color: var(--text-secondary);"
      >
        {strings.about_label}
      </span>

      <!-- Large statement -->
      <h2
        class="mt-8 text-xl font-light leading-relaxed sm:text-2xl lg:text-3xl"
        style="color: var(--text-primary); letter-spacing: -0.4px; line-height: 1.5;"
        set:html={strings.about_headline.replace(
          locale === "es"
            ? "viajeros jóvenes, curiosos y con ganas de adrenalina"
            : "young, curious travelers",
          `<span class="font-semibold text-[var(--tag-green)]">${
            locale === "es"
              ? "viajeros jóvenes, curiosos y con ganas de adrenalina"
              : "young, curious travelers"
          }</span>`
        )}
      />

      <p
        class="mt-6 text-sm font-light leading-relaxed sm:text-base lg:text-lg"
        style="color: var(--text-secondary); line-height: 1.7;"
      >
        {strings.about_paragraph_1}
      </p>

      <p
        class="mt-4 text-sm font-light leading-relaxed sm:text-base lg:text-lg"
        style="color: var(--text-secondary); line-height: 1.7;"
        set:html={strings.about_paragraph_2.replace(
          locale === "es"
            ? "spots increíbles que merecían ser descubiertos"
            : "incredible spots that deserved to be discovered",
          `<span class="font-semibold" style="color: var(--text-primary);">${
            locale === "es"
              ? "spots increíbles que merecían ser descubiertos"
              : "incredible spots that deserved to be discovered"
          }</span>`
        )}
      />
    </div>
  </div>
</section>
