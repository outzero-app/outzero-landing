---
/**
 * Spot types showcase — flowing inline layout, no cards, no links.
 * Icons and labels displayed in a clean, organic horizontal flow
 * with subtle separators.
 */
import type { Locale } from "../i18n/translations";
import { t } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);

const spotTypes = [
  { icon: "/icons/spots/surf.svg", name: strings.spot_surf },
  { icon: "/icons/spots/beach.svg", name: strings.spot_beach },
  { icon: "/icons/spots/summit.svg", name: strings.spot_summit },
  { icon: "/icons/spots/viewpoint.svg", name: strings.spot_viewpoint },
  { icon: "/icons/spots/cliff_jumping.svg", name: strings.spot_cliff_jumping },
  { icon: "/icons/spots/waterfall.svg", name: strings.spot_waterfalls },
  { icon: "/icons/spots/lake.svg", name: strings.spot_lake },
  { icon: "/icons/spots/natural_pools.svg", name: strings.spot_natural_pools },
  { icon: "/icons/spots/caves.svg", name: strings.spot_caves },
  { icon: "/icons/spots/diving.svg", name: strings.spot_diving },
  { icon: "/icons/spots/adventure.svg", name: strings.spot_adventure },
];
---

<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center">
      <h2
        class="text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl"
        style="color: var(--text-primary); letter-spacing: -0.8px;"
      >
        {strings.spot_types_title}
      </h2>
      <p
        class="mx-auto mt-3 max-w-xl text-sm font-light sm:text-base"
        style="color: var(--text-secondary);"
      >
        {strings.spot_types_subtitle}
      </p>
    </div>

    <!-- Spot types — flowing inline layout -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-x-6 gap-y-5 sm:gap-x-8 md:gap-x-10">
      {spotTypes.map((spot, i) => (
        <div class="spot-type-item flex items-center gap-2">
          <img
            src={spot.icon}
            alt=""
            class="spot-icon h-6 w-6 sm:h-7 sm:w-7"
            loading="lazy"
            aria-hidden="true"
          />
          <span
            class="text-xs font-semibold tracking-wide uppercase sm:text-sm"
            style="color: var(--text-primary);"
          >
            {spot.name}
          </span>
          {i < spotTypes.length - 1 && (
            <span
              class="ml-4 hidden text-xs sm:ml-6 sm:inline-block md:ml-8"
              style="color: var(--border);"
              aria-hidden="true"
            >
              /
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .spot-type-item {
    transition: opacity 0.2s ease;
  }
  .spot-type-item:hover {
    opacity: 0.7;
  }
</style>
