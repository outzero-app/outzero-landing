---
import type { Locale } from "../i18n/translations";
import { t } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
---

<footer
  class="border-t py-10"
  style="border-color: var(--border); background: var(--background);"
>
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-6 lg:flex-row lg:justify-between lg:px-8">
    <!-- Logo -->
    <a href="/" aria-label="Outzero home">
      <img
        src="/images/outzero_logo_white.svg"
        alt="Outzero"
        class="h-5 w-auto footer-logo"
      />
    </a>

    <!-- Links -->
    <div class="flex items-center gap-6 text-xs font-light" style="color: var(--text-secondary);">
      <a
        href="https://web.outzero.app"
        class="transition-colors hover:text-[var(--text-primary)]"
      >
        {strings.footer_open_app}
      </a>
      <span style="color: var(--border);">|</span>
      <a
        href="https://web.outzero.app/account/privacy-policy"
        class="transition-colors hover:text-[var(--text-primary)]"
      >
        {strings.footer_privacy}
      </a>
      <span style="color: var(--border);">|</span>
      <a
        href="https://web.outzero.app/account/terms-of-use"
        class="transition-colors hover:text-[var(--text-primary)]"
      >
        {strings.footer_terms}
      </a>
    </div>

    <!-- Copyright -->
    <p class="text-xs font-light" style="color: var(--text-secondary);">
      {strings.footer_copyright}
    </p>
  </div>
</footer>

<style>
  [data-theme="light"] .footer-logo {
    filter: brightness(0);
  }
</style>
