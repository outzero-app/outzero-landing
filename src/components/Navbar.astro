---
import type { Locale } from "../i18n/translations";
import { t, alternateLocale, localePrefix } from "../i18n/translations";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const altLocale = alternateLocale(locale);
const altPath = localePrefix(altLocale) || "/";
const altLabel = altLocale.toUpperCase();
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo -->
    <a href={localePrefix(locale) || "/"} class="flex items-center" aria-label="Outzero home">
      <img
        src="/images/outzero_logo_white.svg"
        alt="Outzero"
        class="h-6 w-auto sm:h-7 logo-img"
      />
    </a>

    <!-- Right side: lang switcher + CTA -->
    <div class="flex items-center gap-3 sm:gap-4">
      <!-- Language switcher -->
      <a
        href={altPath}
        class="rounded-[var(--radius-brand)] border border-[var(--border)] px-2.5 py-1 text-xs font-semibold transition-colors hover:border-[var(--text-secondary)]"
        style="color: var(--text-secondary);"
        aria-label={`Switch to ${altLocale === "es" ? "Spanish" : "English"}`}
      >
        {altLabel}
      </a>

      <!-- CTA -->
      <a
        href="https://web.outzero.app"
        class="rounded-[var(--radius-brand)] bg-[var(--tag-green)] px-5 py-2 text-sm font-semibold text-[var(--tag-green-fg)] transition-transform hover:scale-105 active:scale-95"
      >
        {strings.nav_open_app}
      </a>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  if (navbar) {
    window.addEventListener("scroll", () => {
      if (window.scrollY > 40) {
        navbar.classList.add("navbar-scrolled");
      } else {
        navbar.classList.remove("navbar-scrolled");
      }
    });
  }
</script>

<style>
  .navbar-scrolled {
    background-color: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(66, 66, 66, 0.4);
  }

  [data-theme="light"] .navbar-scrolled {
    background-color: rgba(255, 255, 255, 0.75);
    border-bottom: 1px solid rgba(66, 66, 66, 0.15);
  }

  [data-theme="light"] .logo-img {
    filter: brightness(0);
  }
</style>
