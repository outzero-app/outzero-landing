---
/**
 * Hero section — full-viewport intro with CTA.
 * Background uses a subtle gradient + animated grain texture.
 * Typography follows STYLE_GUIDE.md hierarchy.
 */
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden"
>
  <!-- Animated background gradient -->
  <div class="hero-bg absolute inset-0 -z-10" aria-hidden="true"></div>

  <!-- Floating green glow orbs -->
  <div class="hero-orb hero-orb--1 absolute -z-10" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--2 absolute -z-10" aria-hidden="true"></div>
  <div class="hero-orb hero-orb--3 absolute -z-10" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-5xl px-6 py-32 text-center lg:px-8">
    <!-- Logo icon -->
    <div class="mx-auto mb-8 flex justify-center">
      <img
        src="/images/outzero_icon_white.svg"
        alt=""
        class="h-16 w-auto opacity-80 sm:h-20 hero-icon"
        aria-hidden="true"
      />
    </div>

    <!-- Headline -->
    <h1
      class="mx-auto max-w-4xl text-4xl font-semibold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
      style="color: var(--text-primary); letter-spacing: -1px; line-height: 1.1;"
    >
      Discover amazing spots
      <span class="block text-[var(--tag-green)]">around the world</span>
    </h1>

    <!-- Subheadline -->
    <p
      class="mx-auto mt-6 max-w-2xl text-base font-light sm:text-lg md:text-xl"
      style="color: var(--text-secondary); line-height: 1.6;"
    >
      A community of adventurers sharing the best surf breaks, hidden beaches,
      epic waterfalls, summits and secret spots — with real videos, exact
      locations and visual routes on the map.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="https://web.outzero.app"
        class="group relative inline-flex items-center gap-2 rounded-[var(--radius-brand)] bg-[var(--tag-green)] px-8 py-3.5 text-base font-semibold text-[var(--tag-green-fg)] transition-all hover:scale-105 active:scale-95 sm:text-lg"
      >
        Open App
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>

      <a
        href="#features"
        class="inline-flex items-center gap-1.5 rounded-[var(--radius-brand)] border border-[var(--border)] px-6 py-3 text-sm font-semibold transition-colors hover:bg-[var(--surface)]"
        style="color: var(--text-primary);"
      >
        Learn more
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-6 w-6 opacity-40"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
      style="color: var(--text-secondary);"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>

<style>
  /* Background gradient */
  .hero-bg {
    background: radial-gradient(
        ellipse 80% 60% at 50% 120%,
        rgba(205, 250, 177, 0.08) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 60% 50% at 80% 20%,
        rgba(115, 171, 191, 0.05) 0%,
        transparent 60%
      ),
      var(--background);
  }

  /* Floating glow orbs */
  .hero-orb {
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.15;
  }

  .hero-orb--1 {
    width: 400px;
    height: 400px;
    background: var(--color-brand-green);
    top: 10%;
    left: -5%;
    animation: float-1 12s ease-in-out infinite;
  }

  .hero-orb--2 {
    width: 300px;
    height: 300px;
    background: var(--color-accent-blue);
    bottom: 10%;
    right: -5%;
    animation: float-2 15s ease-in-out infinite;
  }

  .hero-orb--3 {
    width: 200px;
    height: 200px;
    background: var(--color-brand-green);
    top: 50%;
    left: 60%;
    animation: float-3 10s ease-in-out infinite;
  }

  @keyframes float-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, -30px); }
  }
  @keyframes float-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-30px, 20px); }
  }
  @keyframes float-3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, -40px); }
  }

  [data-theme="light"] .hero-bg {
    background: radial-gradient(
        ellipse 80% 60% at 50% 120%,
        rgba(43, 79, 10, 0.06) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 60% 50% at 80% 20%,
        rgba(115, 171, 191, 0.06) 0%,
        transparent 60%
      ),
      var(--background);
  }

  [data-theme="light"] .hero-icon {
    filter: brightness(0);
  }

  [data-theme="light"] .hero-orb {
    opacity: 0.08;
  }
</style>
