---
/**
 * Features section — highlights the main app capabilities.
 * Alternating layout on desktop, stacked on mobile.
 * Uses semantic tokens everywhere.
 */

const features = [
  {
    title: "Interactive Map",
    description:
      "Explore thousands of spots on an interactive map with filters by type, area-based search, satellite view and spot clustering. Find your next destination visually.",
    icon: "map",
  },
  {
    title: "Visual Routes",
    description:
      "Discover multi-day travel routes organized by country, with GPX tracks rendered on the map, daily itineraries and waypoints for every stop.",
    icon: "route",
  },
  {
    title: "Real Media",
    description:
      "Every spot comes with real photos and videos uploaded by the community — no stock images. See the exact conditions before you go.",
    icon: "media",
  },
  {
    title: "Community Driven",
    description:
      "Upload your own discoveries, rate spots, save favorites and share with the global community of adventurers. Together we map the planet.",
    icon: "community",
  },
  {
    title: "Works Everywhere",
    description:
      "Available on iOS, Android and the web — with a responsive desktop layout, shareable URLs and browser history support.",
    icon: "devices",
  },
  {
    title: "Outzero+",
    description:
      "Go premium for offline maps, satellite view, advanced filters and an ad-free experience. Support the project from 1.99\u00A0\u20AC/month.",
    icon: "plus",
  },
];

/**
 * Returns an inline SVG icon for each feature.
 * Kept inline to use currentColor for theme adaptation.
 */
const icons: Record<string, string> = {
  map: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503-11.307a18.48 18.48 0 01-1.756-.996l-.289-.167a4.5 4.5 0 00-4.916 0l-.289.167A18.48 18.48 0 016 6.349v8.573c0 .658.29 1.282.796 1.706l4.476 3.745a1.5 1.5 0 001.956 0l4.476-3.745A2.25 2.25 0 0018 14.922V6.35a18.48 18.48 0 01-2.247-1.307z"/></svg>`,
  route: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
  media: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z"/><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z"/></svg>`,
  community: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>`,
  devices: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/></svg>`,
  plus: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
};
---

<section id="features" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center">
      <span
        class="inline-block rounded-full px-4 py-1 text-xs font-semibold tracking-wider uppercase"
        style="background: var(--tag-green); color: var(--tag-green-fg);"
      >
        Features
      </span>
      <h2
        class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl"
        style="color: var(--text-primary); letter-spacing: -0.8px;"
      >
        Everything you need to explore
      </h2>
      <p
        class="mx-auto mt-3 max-w-xl text-sm font-light sm:text-base"
        style="color: var(--text-secondary);"
      >
        Built for adventurers, by adventurers. Every feature is designed to help you
        discover your next destination.
      </p>
    </div>

    <!-- Features grid -->
    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div
          class="feature-card group rounded-[var(--radius-brand)] border border-[var(--border)] p-6 transition-all hover:border-[var(--tag-green)] sm:p-8"
          style="background: var(--surface);"
        >
          <!-- Icon -->
          <div
            class="mb-4 inline-flex items-center justify-center rounded-[var(--radius-brand)] p-2.5"
            style="background: var(--background); color: var(--tag-green);"
          >
            <Fragment set:html={icons[feature.icon]} />
          </div>

          <!-- Title -->
          <h3
            class="text-lg font-semibold sm:text-xl"
            style="color: var(--text-primary); letter-spacing: -0.3px;"
          >
            {feature.title}
          </h3>

          <!-- Description -->
          <p
            class="mt-2 text-sm font-light leading-relaxed"
            style="color: var(--text-secondary);"
          >
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-card:hover {
    box-shadow: 0 4px 24px rgba(205, 250, 177, 0.06);
    transform: translateY(-2px);
  }

  [data-theme="light"] .feature-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  }
</style>
